            <h3 class="text-white font-semibold mb-4">相关资源</h3>
            <ul class="space-y-3 text-sm text-white/70">
              <li><a href="#" data-link="external-openai" class="group flex items-center gap-2 hover:text-white transition-colors"><span
                    class="w-1 h-1 rounded-full bg-white/50 group-hover:w-2 transition-all"></span>OpenAI 文档</a></li>
              <li><a href="#" data-link="external-claude" class="group flex items-center gap-2 hover:text-white transition-colors"><span
                    class="w-1 h-1 rounded-full bg-white/50 group-hover:w-2 transition-all"></span>Claude 文档</a></li>
              <li><a href="#" data-link="api-status" class="group flex items-center gap-2 hover:text-white transition-colors"><span
                    class="w-1 h-1 rounded-full bg-white/50 group-hover:w-2 transition-all"></span>服务状态</a></li>
            </ul>
          </div>
          <!-- <div>
            <h3 class="text-white font-semibold mb-4">友情链接</h3>
            <ul class="space-y-3 text-sm">
              <li><a href="https://help.weelinking.com"                  class="group flex items-center gap-2 hover:text-white transition-colors"><span
                    class="w-1 h-1 bg-purple-500 rounded-full group-hover:w-2 transition-all"></span>weelinking 博客</a></li>
              <li><a href="https://llmapi.fit/"                  class="group flex items-center gap-2 hover:text-white transition-colors"><span
                    class="w-1 h-1 bg-purple-500 rounded-full group-hover:w-2 transition-all"></span>回声笔降AIGC</a></li>
              <li><a href="https://cldcode.com/"                  class="group flex items-center gap-2 hover:text-white transition-colors"><span
                    class="w-1 h-1 bg-purple-500 rounded-full group-hover:w-2 transition-all"></span>ClaudeCode代办</a>
              </li>
            </ul>
          </div> -->
        </div>
        <div class="mt-12 pt-8" style="border-top: 1px solid rgba(255,255,255,0.1);">
          <div class="flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex flex-col md:flex-row items-center gap-4 text-sm" style="color: rgba(255,255,255,0.5);">
              <span>©2025-2026 weelinking All rights reserved</span>
              <span class="hidden md:inline" style="margin: 0 8px;">|</span>
              <a href="#" data-link="external-beian" target="_blank" class="hover:text-white transition-colors">粤ICP备2025509392号-1</a>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </div>
  <script>
    // ========== FAQ 折叠/展开功能 ==========
    document.querySelectorAll('#faq button[aria-expanded]').forEach(button => {
      button.addEventListener('click', () => {
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        const content = button.nextElementSibling;
        const icon = button.querySelector('svg');
        const container = button.parentElement;
        const numberBadge = button.querySelector('.flex.h-8.w-8');

        // 切换展开状态
        button.setAttribute('aria-expanded', !isExpanded);

        if (!isExpanded) {
          // 展开
          content.classList.remove('max-h-0');
          content.classList.add('max-h-96');
          icon.classList.add('rotate-180', 'text-blue-600');
          container.classList.remove('bg-white', 'ring-1', 'ring-gray-200', 'hover:ring-blue-500/10');
          container.classList.add('bg-gradient-to-br', 'from-blue-50', 'to-indigo-50', 'ring-2', 'ring-blue-500/20');
          numberBadge.classList.remove('bg-gray-100', 'text-gray-600');
          numberBadge.classList.add('bg-gradient-to-br', 'from-blue-500', 'to-indigo-500', 'text-white');
        } else {
          // 折叠
          content.classList.remove('max-h-96');
          content.classList.add('max-h-0');
          icon.classList.remove('rotate-180', 'text-blue-600');
          container.classList.remove('bg-gradient-to-br', 'from-blue-50', 'to-indigo-50', 'ring-2', 'ring-blue-500/20');
          container.classList.add('bg-white', 'ring-1', 'ring-gray-200', 'hover:ring-blue-500/10');
          numberBadge.classList.remove('bg-gradient-to-br', 'from-blue-500', 'to-indigo-500', 'text-white');
          numberBadge.classList.add('bg-gray-100', 'text-gray-600');
        }
      });
    });

    // 获取所有 Tab 按钮和内容
        const tabBtns = document.querySelectorAll('.tab-btn');
        const tabContents = document.querySelectorAll('.tab-content');
        const copyBtn = document.getElementById('copyBtn');
        const copyText = document.getElementById('copyText');

        // Tab 切换逻辑
        tabBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                // 移除所有按钮的激活样式
                tabBtns.forEach(b => {
                    b.classList.remove('bg-gray-800', 'text-white', 'border-b-2', 'border-blue-500');
                    b.classList.add('text-gray-400');
                });

                // 添加当前按钮的激活样式
                btn.classList.remove('text-gray-400');
                btn.classList.add('bg-gray-800', 'text-white', 'border-b-2', 'border-blue-500');

                // 隐藏所有内容
                tabContents.forEach(content => {
                    content.classList.add('hidden');
                    content.classList.remove('active');
                });

                // 显示当前内容
                const tabId = btn.getAttribute('data-tab');
                const activeContent = document.getElementById(`${tabId}-content`);
                activeContent.classList.remove('hidden');
                activeContent.classList.add('active');
            });
        });

        // 复制代码功能
        copyBtn.addEventListener('click', () => {
            // 获取当前激活的代码内容
            const activeCode = document.querySelector('.tab-content.active pre code').textContent;
            
            // 复制到剪贴板
            navigator.clipboard.writeText(activeCode).then(() => {
                copyText.textContent = '已复制';
                setTimeout(() => {
                    copyText.textContent = '复制';
                }, 2000);
            }).catch(err => {
                console.error('复制失败:', err);
                copyText.textContent = '复制失败';
                setTimeout(() => {
                    copyText.textContent = '复制';
                }, 2000);
            });
        });
    // 等待DOM加载完成后执行
    document.addEventListener('DOMContentLoaded', function () {
      // 1. 获取DOM元素
      const prevBtn = document.getElementById('prevBtn'); // 上一页按钮
      const nextBtn = document.getElementById('nextBtn'); // 下一页按钮
      const dotContainer = document.getElementById('dotContainer'); // 圆点容器
      const dots = dotContainer.querySelectorAll('button'); // 所有圆点按钮
      const playPauseBtn = document.getElementById('playPauseBtn'); // 暂停/播放按钮
      const playPauseIcon = document.getElementById('playPauseIcon'); // 暂停/播放图标
      const noticeItems = document.querySelectorAll('.notice-item'); // 所有公告项

      // 2. 轮播核心配置
      const config = {
        total: dots.length, // 轮播总数（圆点数量）
        currentIndex: 1, // 当前激活索引（初始为第2条，对应data-index=1）
        interval: 3000, // 自动轮播间隔（毫秒）
        isPaused: false, // 是否暂停轮播
        timer: null // 自动轮播定时器
      };

      // 3. 更新圆点激活状态和公告内容显示
      function updateCarouselStatus() {
        // 更新圆点状态
        dots.forEach((dot, index) => {
          if (index === config.currentIndex) {
            dot.classList.remove('bg-white/40');
            dot.classList.add('bg-white');
          } else {
            dot.classList.remove('bg-white');
            dot.classList.add('bg-white/40');
          }
        });

        // 更新公告内容显示
        noticeItems.forEach((item, index) => {
          item.style.display = index === config.currentIndex ? 'flex' : 'none';
        });
      }

      // 4. 切换轮播页（核心函数）
      function switchToIndex(targetIndex) {
        // 边界处理：循环轮播（超出范围则回到另一端）
        if (targetIndex < 0) {
          config.currentIndex = config.total - 1;
        } else if (targetIndex >= config.total) {
          config.currentIndex = 0;
        } else {
          config.currentIndex = targetIndex;
        }
        // 更新轮播状态
        updateCarouselStatus();
      }

      // 5. 启动自动轮播
      function startAutoPlay() {
        // 先清除已有定时器（避免重复）
        if (config.timer) clearInterval(config.timer);
        // 非暂停状态下启动定时器
        if (!config.isPaused) {
          config.timer = setInterval(() => {
            switchToIndex(config.currentIndex + 1);
          }, config.interval);
        }
      }

      // 6. 暂停自动轮播
      function pauseAutoPlay() {
        clearInterval(config.timer);
        config.timer = null;
      }

      // 7. 切换暂停/播放状态
      function togglePlayPause() {
        config.isPaused = !config.isPaused;
        if (config.isPaused) {
          // 暂停状态：清除定时器 + 切换为播放图标
          pauseAutoPlay();
          playPauseIcon.innerHTML = '<path d="M8 5v14l11-7z"></path>'; // 播放图标（三角形）
          playPauseBtn.setAttribute('aria-label', '播放轮播');
        } else {
          // 播放状态：启动定时器 + 切换为暂停图标
          startAutoPlay();
          playPauseIcon.innerHTML = '<path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"></path>'; // 暂停图标（双竖线）
          playPauseBtn.setAttribute('aria-label', '暂停轮播');
        }
      }

      // 8. 绑定事件监听
      // 上一页按钮
      prevBtn.addEventListener('click', () => {
        switchToIndex(config.currentIndex - 1);
        // 点击后重置自动轮播定时器（避免快速点击导致轮播混乱）
        startAutoPlay();
      });

      // 下一页按钮
      nextBtn.addEventListener('click', () => {
        switchToIndex(config.currentIndex + 1);
        startAutoPlay();
      });

      // 圆点按钮（点击跳转对应页）
      dots.forEach(dot => {
        dot.addEventListener('click', () => {
          const targetIndex = parseInt(dot.getAttribute('data-index'));
          switchToIndex(targetIndex);
          startAutoPlay();
        });
      });

      // 暂停/播放按钮
      playPauseBtn.addEventListener('click', togglePlayPause);

      // 9. 初始化
      updateCarouselStatus(); // 初始更新轮播状态
      startAutoPlay(); // 启动自动轮播

      // 【优化】页面隐藏时暂停轮播，显示时恢复
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          pauseAutoPlay();
        } else if (!config.isPaused) {
          startAutoPlay();
        }
      });
    });
  </script>
  <script src="./config.js?v=3"></script>
  <script>
    // Intersection Observer for fade-in animations
    document.addEventListener('DOMContentLoaded', () => {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      });

      document.querySelectorAll('.fade-in-up').forEach(el => observer.observe(el));
      
      // 性能优化：页面隐藏时暂停动画
      document.addEventListener('visibilitychange', () => {
        const animatedElements = document.querySelectorAll('.glass-orb, .animate-float, .animate-float-slow');
        if (document.hidden) {
          animatedElements.forEach(el => el.style.animationPlayState = 'paused');
        } else {
          animatedElements.forEach(el => el.style.animationPlayState = 'running');
        }
      });
    });
  </script>
</body>

</html>