                <!-- cURL 代码 -->
                <div class="tab-content active" id="curl-content">
                  <pre class="text-sm overflow-x-auto"><code class="whitespace-pre" style="color: #f1f5f9 !important;">
curl https://api.weelinking.com/v1/chat/completions \
-H "Content-Type: application/json" \
-H "Authorization: Bearer sk-您的API密钥" \
-d '{
  "model": "gpt-4o",
  "messages": [
    {"role": "user", "content": "写一个马年的祝福语"}
  ]
}'</code></pre>
                </div>

                <!-- Node.js 代码 -->
                <div class="tab-content hidden" id="nodejs-content">
                  <pre class="text-sm overflow-x-auto"><code class="whitespace-pre" style="color: #f1f5f9 !important;">
import OpenAI from "openai";

const openai = new OpenAI({
  apiKey: "sk-您的API密钥",
  baseURL: "https://api.weelinking.com/v1"
});

const completion = await openai.chat.completions.create({
  model: "gpt-4o",
  messages: [
    {"role": "user", "content": "写一个马年的祝福语"}
  ]
});

console.log(completion.choices[0].message);</code></pre>
                </div>

                <!-- Python 代码 -->
                <div class="tab-content hidden" id="python-content">
                  <pre class="text-sm overflow-x-auto"><code class="whitespace-pre" style="color: #f1f5f9 !important;">
from openai import OpenAI

client = OpenAI(
    api_key="sk-您的API密钥",
    base_url="https://api.weelinking.com/v1"
)

completion = client.chat.completions.create(
    model="gpt-4o",
    messages=[
        {"role": "user", "content": "写一个马年的祝福语"}
    ]
)

print(completion.choices[0].message)</code></pre>
