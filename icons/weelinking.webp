                <p class="mt-2" style="color: rgba(26, 26, 46, 0.7);">7×24小时在线，即时响应</p>
              </div>
            </div>
            <div class="mt-12"><a href="#" data-link="api-login" class="inline-flex items-center justify-center px-6 py-3 rounded-full text-base font-semibold whitespace-nowrap transition-all duration-300" style="background: rgba(255,255,255,0.9); color: #667eea; box-shadow: 0 4px 15px rgba(0,0,0,0.1);" onmouseover="this.style.background='white'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 25px rgba(0,0,0,0.15)';" onmouseout="this.style.background='rgba(255,255,255,0.9)'; this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(0,0,0,0.1)';">
                <div class="flex items-center gap-3"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"></path>
                  </svg>一键登录</div>
              </a></div>
          </div>
        </div>
      </div>
    </main>
    <footer class="relative text-white/80 overflow-hidden" style="background: rgba(15,15,35,0.95); backdrop-filter: blur(20px); border-top: 1px solid rgba(255,255,255,0.1);">
      <div class="absolute inset-0 opacity-20">
        <div
          class="absolute -top-40 -right-40 w-80 h-80 rounded-full filter blur-3xl" style="background: radial-gradient(circle, rgba(102,126,234,0.5), transparent 70%);">
        </div>
        <div
          class="absolute -bottom-40 -left-40 w-80 h-80 rounded-full filter blur-3xl" style="background: radial-gradient(circle, rgba(240,147,251,0.4), transparent 70%);">
        </div>
      </div>
      <div class="mx-auto max-w-7xl px-6 lg:px-8 relative py-16">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-5">
          <div class="lg:col-span-2"><a class="flex items-center gap-2" href="/"><img alt="weelinking Logo" loading="lazy"
                width="40" height="40" decoding="async" data-nimg="1" class="h-10 w-10" style="color:transparent"
                src="./img/logo.png"><span class="text-2xl font-bold text-white">weelinking</span></a>
            <p class="mt-4 text-sm text-white/70">企业级专业稳定的 OpenAI &amp; Claude API 中转站</p>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-4">快速链接</h3>
            <ul class="space-y-3 text-sm text-white/70">
              <li><a class="group flex items-center gap-2 hover:text-white transition-colors" href="#" data-link="api-quick-start"><span
                    class="w-1 h-1 rounded-full bg-white/50 group-hover:w-2 transition-all"></span>快速开始</a></li>
              <li><a class="group flex items-center gap-2 hover:text-white transition-colors" href="#" data-link="api-changelog"><span
                    class="w-1 h-1 rounded-full bg-white/50 group-hover:w-2 transition-all"></span>公告中心</a></li>
              <li><a class="group flex items-center gap-2 hover:text-white transition-colors"
                  href="#" data-link="docs-home"><span
                    class="w-1 h-1 rounded-full bg-white/50 group-hover:w-2 transition-all"></span>API 文档</a></li>
              <li><a class="group flex items-center gap-2 hover:text-white transition-colors" href="/terms"><span
                    class="w-1 h-1 rounded-full bg-white/50 group-hover:w-2 transition-all"></span>用户协议</a></li>
              <li><a class="group flex items-center gap-2 hover:text-white transition-colors" href="/privacy"><span
                    class="w-1 h-1 rounded-full bg-white/50 group-hover:w-2 transition-all"></span>隐私政策</a></li>
