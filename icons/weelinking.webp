<!DOCTYPE html>
<html lang="zh-CN">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Weelinking - AI API 服务平台</title>
  <meta name="description" content="Weelinking提供稳定可靠的AI API服务，支持GPT、Claude、DeepSeek等主流模型">
  
  <!-- DNS 预取 - 加速外部资源 -->
  <link rel="dns-prefetch" href="//api.weelinking.com">
  <link rel="dns-prefetch" href="//docs.weelinking.com">
  <link rel="preconnect" href="https://api.weelinking.com" crossorigin>
  
  <!-- 图标和关键资源 -->
  <link rel="icon" href="./img/favicon.ico">
  <link rel="preload" href="./style.css" as="style">
  <link rel="preload" href="./img/logo.png" as="image" fetchpriority="high">
  <link rel="stylesheet" href="./style.css">
  
  <!-- 关键CSS内联 - 首屏渲染 -->
  <style>
    /* 使用系统字体栈，避免外部字体加载 */
    body { 
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Helvetica Neue", Helvetica, Arial, sans-serif;
      margin: 0;
      background: linear-gradient(135deg, #e8eaf6 0%, #e1f5fe 25%, #f3e5f5 50%, #e8eaf6 75%, #e1f5fe 100%);
      background-attachment: fixed;
      min-height: 100vh;
    }
    
    /* 首屏关键样式内联 */
    .nav-loading {
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }
    
    /* 锚点偏移 - 防止固定导航栏遮挡标题 */
    [id] {
      scroll-margin-top: 100px;
    }
    html {
      scroll-behavior: smooth;
    }
    
    /* Animation classes */
    .fade-in-up {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
      will-change: opacity, transform;
    }
    .fade-in-up.visible {
      opacity: 1;
      transform: translateY(0);
    }
    
    .delay-100 { transition-delay: 0.1s; }
    .delay-200 { transition-delay: 0.2s; }
    .delay-300 { transition-delay: 0.3s; }
    .delay-400 { transition-delay: 0.4s; }
    .delay-500 { transition-delay: 0.5s; }

    /* Float animation */
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }
    .animate-float {
      animation: float 5s ease-in-out infinite;
    }
    
    /* Hover Glow effect for glassmorphism */
    .hover-glow {
      transition: all 0.3s ease;
      background: rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
    }
    .hover-glow:hover {
      transform: translateY(-2px);
      background: rgba(255, 255, 255, 0.25);
      box-shadow: 0 8px 32px rgba(31, 38, 135, 0.2);
    }

    /* 玻璃拟态浮动球装饰 - 移除backdrop-filter优化性能 */
    .glass-orb {
      position: absolute;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, rgba(102, 126, 234, 0.15), rgba(168, 85, 247, 0.08) 50%, transparent 70%);
      border: 1px solid rgba(255, 255, 255, 0.3);
      box-shadow: 0 8px 32px rgba(102, 126, 234, 0.1);
    }
    .glass-orb-1 {
      width: 180px;
      height: 180px;
      top: 10%;
      left: 5%;
      animation: float 10s ease-in-out infinite;
    }
    .glass-orb-2 {
      width: 120px;
      height: 120px;
      top: 60%;
      right: 10%;
      animation: float 12s ease-in-out infinite reverse;
    }
    
    /* 减少动画触发频率 - 性能优化 */
    @media (prefers-reduced-motion: reduce) {
      .glass-orb, .animate-float, .animate-float-slow {
        animation: none !important;
      }
    }
  </style>
</head>

<body>
  <div style="display: none;">
    <!-- <div class="bg-gradient-to-r from-blue-600 to-indigo-600 py-3 px-4"> -->
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center justify-between">
          <!-- 公告内容区域 -->
          <div class="flex items-center gap-3 min-w-0 flex-1">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
              stroke="currentColor" aria-hidden="true" class="h-5 w-5 text-white flex-shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z">
              </path>
            </svg>
            <!-- 公告列表（轮播内容） -->
            <!-- <div class="flex items-center gap-2 min-w-0 notice-container"> -->
              <!-- 公告1 -->
              <div class="notice-item" data-index="0" style="display: none;">
                <span class="text-sm font-medium text-white flex-shrink-0">重磅上线</span>
                <a href="#" data-link="docs-changelog" class="text-sm text-white/90 hover:text-white transition-colors truncate">✨ 08/08 GPT-5 全系列
                  正式上线，官网同价，充值加赠+汇率优势约8折</a>
              </div>
              <!-- 公告2（初始显示） -->
              <div class="notice-item" data-index="1" style="display: flex;">
                <span class="text-sm font-medium text-white flex-shrink-0">性能升级</span>
                <a href="#" data-link="docs-changelog" class="text-sm text-white/90 hover:text-white transition-colors truncate">🎨 08/07 Claude Opus 4.1
                  性能升级版上线，加量不加价</a>
              </div>
              <!-- 公告3 -->
              <div class="notice-item" data-index="2" style="display: none;">
                <span class="text-sm font-medium text-white flex-shrink-0">开源模型</span>
                <a href="#" data-link="docs-changelog" class="text-sm text-white/90 hover:text-white transition-colors truncate">🚀 08/06 OpenAI 开源模型
                  gpt-oss-120b 和 gpt-oss-20b 上线，价格低于 DeepSeek R1/V3</a>
              </div>
            </div>
          </div>
          <!-- 轮播控制按钮（补充ID属性） -->
          <div class="flex items-center gap-2 ml-4">
            <!-- 上一条按钮 -->
            <button id="prevBtn" class="p-1 text-white/70 hover:text-white transition-colors" aria-label="上一条公告">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                stroke="currentColor" aria-hidden="true" class="h-4 w-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"></path>
              </svg>
            </button>
            <!-- 圆点指示器（补充ID和data-index） -->
            <div id="dotContainer" class="flex gap-1">
              <button class="w-2 h-2 rounded-full transition-colors bg-white/40" aria-label="跳转到第1条公告"
                data-index="0"></button>
              <button class="w-2 h-2 rounded-full transition-colors bg-white" aria-label="跳转到第2条公告"
                data-index="1"></button>
              <button class="w-2 h-2 rounded-full transition-colors bg-white/40" aria-label="跳转到第3条公告"
                data-index="2"></button>
            </div>
            <!-- 下一条按钮 -->
            <button id="nextBtn" class="p-1 text-white/70 hover:text-white transition-colors" aria-label="下一条公告">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                stroke="currentColor" aria-hidden="true" class="h-4 w-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"></path>
              </svg>
            </button>
            <!-- 暂停/播放按钮（补充ID） -->
            <button id="playPauseBtn" class="p-1 text-white/70 hover:text-white transition-colors ml-2"
              aria-label="暂停轮播">
              <svg id="playPauseIcon" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
    <nav class="sticky top-0 z-50 glass-nav" style="background: rgba(255,255,255,0.7); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(0,0,0,0.08);">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="flex items-center justify-between py-6"><a class="flex items-center gap-2" href="/"><img
              alt="weelinking Logo" width="40" height="40" decoding="async" data-nimg="1" class="h-10 w-10 animate-float-slow"
              style="color:transparent" src="./img/logo.png"><span
              class="text-2xl font-bold" style="color: #1a1a2e;">weelinking</span></a>
          <div class="hidden md:flex items-center space-x-8"><a
              class="font-medium transition-colors" style="color: rgba(26, 26, 46, 0.7);" onmouseover="this.style.color='#1a1a2e'" onmouseout="this.style.color='rgba(26, 26, 46, 0.7)'" href="/">首页</a><a
              class="font-medium transition-colors" style="color: rgba(26, 26, 46, 0.7);" onmouseover="this.style.color='#1a1a2e'" onmouseout="this.style.color='rgba(26, 26, 46, 0.7)'" href="#features">功能</a><a
              class="font-medium transition-colors" style="color: rgba(26, 26, 46, 0.7);" onmouseover="this.style.color='#1a1a2e'" onmouseout="this.style.color='rgba(26, 26, 46, 0.7)'" href="#code-examples">代码示例</a><a
              class="font-medium transition-colors" style="color: rgba(26, 26, 46, 0.7);" onmouseover="this.style.color='#1a1a2e'" onmouseout="this.style.color='rgba(26, 26, 46, 0.7)'" href="#faq">常见问题</a><a
              href="#" data-link="docs-home" class="font-medium transition-colors" style="color: rgba(26, 26, 46, 0.7);" onmouseover="this.style.color='#1a1a2e'" onmouseout="this.style.color='rgba(26, 26, 46, 0.7)'">API文档</a><a
              class="font-medium transition-colors" style="color: rgba(26, 26, 46, 0.7);" onmouseover="this.style.color='#1a1a2e'" onmouseout="this.style.color='rgba(26, 26, 46, 0.7)'" href="#contact">联系我们</a><a
              href="#" data-link="api-user-center" class="inline-flex items-center justify-center rounded-full px-5 py-2.5 text-sm font-semibold transition-all duration-300" style="background: linear-gradient(135deg, #667eea 0%, #a855f7 100%); color: white; box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 30px rgba(102, 126, 234, 0.6)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 20px rgba(102, 126, 234, 0.4)';">开始使用</a>
          </div><button class="md:hidden rounded-lg p-2 hover:bg-black/5" style="color: #1a1a2e;" aria-label="打开菜单"
            title="打开菜单"><svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg></button>
        </div>
      </div>
    </nav>
    <div class="relative overflow-hidden min-h-screen flex flex-col justify-center">
      <!-- 玻璃拟态风格背景 - 已通过 body CSS 设置 -->
      <!-- 装饰性浮动球 - 简化版本优化性能 -->
      <div class="glass-orb glass-orb-1"></div>
      <div class="glass-orb glass-orb-2"></div>
      <div class="mx-auto max-w-7xl px-6 lg:px-8 relative">
