<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="64" height="64">
  <!-- Dark background matching Claw402 brand -->
  <rect width="64" height="64" rx="11" fill="#0d0f14"/>
  <!-- "C" arc in silver/gray -->
  <path d="M46,16 L24,16 Q12,16 12,28 L12,36 Q12,48 24,48 L46,48"
        fill="none" stroke="#8a9ab0" stroke-width="7.5" stroke-linecap="round"/>
  <!-- Top-left crosshair notch on the C -->
  <rect x="20" y="12" width="7" height="7" rx="1.5" fill="#0d0f14"/>
  <rect x="20" y="12" width="7" height="7" rx="1.5" fill="none" stroke="#8a9ab0" stroke-width="1.5"/>
  <!-- Blue "02" hint -->
  <text x="47" y="34"
        font-family="'Arial Black','Impact',sans-serif"
        font-size="11"
        font-weight="900"
        fill="#3B6FE8"
        text-anchor="middle"
        dominant-baseline="middle">02</text>
</svg>
